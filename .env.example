# =========================================================================
# Pathfinder App — Environment Configuration TEMPLATE
# =========================================================================
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# The autonomous loop NEVER uses real keys; it runs against hermetic mocks
# (see test/fixtures + MSW). Real keys are only for local manual QA / staging.
# =========================================================================

# -- 1. Mapbox (CLIENT-SIDE, exposed in the bundle by design) --------------
# The ONLY credential allowed to reach the browser. Restrict it by URL/origin
# in the Mapbox dashboard to your one deployed domain. Free tier: 50,000 map
# loads/month (not 100k). Obtain at https://account.mapbox.com/
VITE_MAPBOX_ACCESS_TOKEN=pk.REPLACE_ME

# -- 2. OpenRouteService (SERVER-ONLY — snap-to-trail routing) -------------
# Free tier: 2,000 requests/day, 40 requests/minute. https://openrouteservice.org/
ORS_API_KEY=REPLACE_ME

# -- 3. OpenWeather One Call 3.0 (SERVER-ONLY — forecast & rain) -----------
# Requires a card on file ("One Call by Call" subscription). To guarantee $0,
# lower the account "Calls per day (no more than)" limit from the 2,000 default
# to 1,000. https://openweathermap.org/api/one-call-3
OPENWEATHER_API_KEY=REPLACE_ME

# -- 4. Gateway runtime ----------------------------------------------------
NODE_ENV=development
PORT=8080

# -- 5. CORS allow-list (comma-separated origins; dev + WebView) -----------
# Prod is same-origin (Express serves the built SPA), so this is mainly for dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# -- 6. Public base URL of the deployed app (for Mapbox restriction docs) --
PUBLIC_BASE_URL=http://localhost:8080
